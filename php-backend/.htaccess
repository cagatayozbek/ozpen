# Güvenlik ayarları
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# CORS headers
<IfModule mod_headers.c>
    SetEnvIfNoCase Origin "^https?://(www\.)?ozpenpvc\.com\.tr$" ORIGIN_OK=$0
    SetEnvIfNoCase Origin "^http://localhost:(3000|4173)$" ORIGIN_OK=$0
    Header set Access-Control-Allow-Origin "%{ORIGIN_OK}e" env=ORIGIN_OK
    Header set Access-Control-Allow-Credentials "true" env=ORIGIN_OK
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRF-Token"
</IfModule>
